# Supabase 配置（必填）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Edge Function check-link（可选）
# ALLOWED_ORIGINS=https://herrhel.github.io
# CHECK_LINK_TIMEOUT_MS=10000

# ── L2 真后端 Playwright（可选，默认 CI 不跑）──
# LV_E2E_L2=1
# 会话二选一：
# 1) 从已登录浏览器 DevTools → Application → localStorage → linkvault_auth 整段复制：
# LV_E2E_L2_SESSION_JSON={"access_token":"...","refresh_token":"...","user":{"id":"...","email":"..."}}
# 2) 分字段：
# LV_E2E_L2_ACCESS_TOKEN=
# LV_E2E_L2_REFRESH_TOKEN=
# LV_E2E_L2_USER_ID=
# LV_E2E_L2_EMAIL=
