{
  "manifest_version": 3,
  "name": "LinkVault",
  "version": "1.0.0",
  "description": "知识工作者的链接中枢 — 一键收藏、智能搜索、云端同步",
  "permissions": [
    "sidePanel",
    "activeTab",
    "bookmarks",
    "storage"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "打开 LinkVault 侧边栏"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "idle"
    }
  ],
  "icons": {}
}

