{
  "manifest_version": 3,
  "name": "LinkVault",
  "version": "1.1.1",
  "description": "一键保存网页到 LinkVault 书签管理器",
  "permissions": [
    "sidePanel",
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://herrhel.github.io/*",
    "http://localhost:5173/*",
    "https://localhost:5173/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "打开 LinkVault 侧边栏"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "save-to-linkvault": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "打开 LinkVault 保存当前页面"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
