{
  "manifest_version": 3,
  "name": "LinkVault",
  "version": "1.0.0",
  "description": "知识工作者的链接中枢 — 一键收藏、智能搜索、云端同步",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "https://*.supabase.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://*.supabase.co wss://*.supabase.co"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "打开 LinkVault 侧边栏"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "save-to-linkvault": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "保存当前页面到 LinkVault"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
